<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CAP.Avalonia.ViewModels.Analysis.OnaAnalysis"
        xmlns:oxy="using:OxyPlot.Avalonia"
        x:Class="CAP.Avalonia.Views.Dialogs.OnaAnalyzerWindow"
        x:DataType="vm:OnaSweepViewModel"
        Title="{Binding WindowTitle}"
        Width="780" Height="560"
        MinWidth="520" MinHeight="380"
        Background="#1e1e1e"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="14">

        <!-- Top: Title -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding WindowTitle}"
                   FontWeight="SemiBold" FontSize="15"
                   Foreground="Cyan" Margin="0,0,0,4"/>
        <TextBlock DockPanel.Dock="Top"
                   Text="Wavelength sweep — Optical Network Analyzer"
                   Foreground="Gray" FontSize="11" Margin="0,0,0,12"/>

        <!-- Bottom: Status + buttons -->
        <Border DockPanel.Dock="Bottom" Background="#161616" Padding="8" Margin="0,10,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Foreground="Gray" FontSize="11"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Run"
                            Command="{Binding RunSweepCommand}"
                            Background="#3d5d5d" Width="80"
                            IsEnabled="{Binding IsSweeping, Converter={x:Static BoolConverters.Not}}"/>
                    <Button Content="Cancel"
                            Command="{Binding CancelSweepCommand}"
                            Background="#5d3d3d" Width="80"
                            IsVisible="{Binding IsSweeping}"/>
                    <Button Content="Export CSV"
                            Command="{Binding ExportCsvCommand}"
                            Background="#3d3d5d" Width="90"
                            IsVisible="{Binding HasResult}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Left: Sweep parameters -->
        <StackPanel DockPanel.Dock="Left" Width="200" Margin="0,0,12,0" Spacing="6">
            <TextBlock Text="Sweep parameters" Foreground="LightGray" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,2"/>

            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Start (nm):" Foreground="Gray" Width="80" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding StartNm}" Minimum="400" Maximum="2500" Increment="10" FormatString="F0" Width="100"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="End (nm):" Foreground="Gray" Width="80" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding EndNm}" Minimum="400" Maximum="2500" Increment="10" FormatString="F0" Width="100"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Steps:" Foreground="Gray" Width="80" VerticalAlignment="Center"/>
                <NumericUpDown Value="{Binding StepCount}" Minimum="2" Maximum="500" Increment="1" FormatString="F0" Width="100"/>
            </StackPanel>

            <TextBlock Text="{Binding WarningText}"
                       Foreground="Gold" FontSize="10" TextWrapping="Wrap"
                       Margin="0,8,0,0"
                       IsVisible="{Binding WarningText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>

        <!-- Centre: Plot -->
        <Border Background="#1a1a1a" BorderBrush="#3d3d3d" BorderThickness="1">
            <oxy:PlotView Model="{Binding PlotModel}" Background="Transparent"/>
        </Border>

    </DockPanel>

</Window>
