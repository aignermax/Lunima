<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CAP.Avalonia.ViewModels.Solvers"
        x:Class="CAP.Avalonia.Views.Dialogs.ModeSolverDialog"
        x:DataType="vm:ModeSolverViewModel"
        Title="Compute Modes for Waveguide"
        Width="480" Height="560"
        MinWidth="400" MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="#1e1e1e"
        Foreground="White">

    <DockPanel Margin="16" LastChildFill="True">

        <!-- Buttons — always visible at the bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
            <Button Content="Cancel Solve"
                    Command="{Binding CancelSolveCommand}"
                    Width="100" Background="#5d3d3d" FontSize="11"
                    IsVisible="{Binding IsSolving}"/>
            <Button Content="Solve"
                    Command="{Binding SolveCommand}"
                    Width="90" Background="#3d4d6d"
                    IsEnabled="{Binding CanSolve}"/>
            <Button Content="Close" x:Name="CloseButton" Width="70" Click="OnCloseClicked"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="10">

                <!-- Title -->
                <TextBlock Text="Waveguide Mode Solver" FontSize="15" FontWeight="SemiBold"
                           Foreground="LightBlue"/>
                <TextBlock Text="Computes n_eff, n_g and polarisation for guided modes via a Python FDE solver."
                           Foreground="Gray" FontSize="10" TextWrapping="Wrap"/>

                <Separator Background="#3d3d3d"/>

                <!-- Cross-section geometry -->
                <TextBlock Text="Cross-section geometry" Foreground="#aaaaaa" FontSize="11"
                           FontWeight="SemiBold"/>

                <Grid ColumnDefinitions="*,8,*" RowDefinitions="Auto,8,Auto,8,Auto">

                    <!-- Width -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Core width (µm):"
                               Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="0" Grid.Column="2"
                                  Value="{Binding Width}"
                                  Minimum="0.1" Maximum="5.0" Increment="0.05"
                                  FormatString="F3"
                                  Background="#2d2d2d" Foreground="White"/>

                    <!-- Height -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Core height (µm):"
                               Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="2" Grid.Column="2"
                                  Value="{Binding Height}"
                                  Minimum="0.05" Maximum="2.0" Increment="0.02"
                                  FormatString="F3"
                                  Background="#2d2d2d" Foreground="White"/>

                    <!-- Slab height -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Slab height (µm, 0 = strip):"
                               Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="4" Grid.Column="2"
                                  Value="{Binding SlabHeight}"
                                  Minimum="0.0" Maximum="2.0" Increment="0.01"
                                  FormatString="F3"
                                  Background="#2d2d2d" Foreground="White"/>
                </Grid>

                <Separator Background="#3d3d3d"/>

                <!-- Refractive indices -->
                <TextBlock Text="Refractive indices" Foreground="#aaaaaa" FontSize="11"
                           FontWeight="SemiBold"/>

                <Grid ColumnDefinitions="*,8,*" RowDefinitions="Auto,8,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Core index (n_core):"
                               Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="0" Grid.Column="2"
                                  Value="{Binding CoreIndex}"
                                  Minimum="1.0" Maximum="5.0" Increment="0.01"
                                  FormatString="F3"
                                  Background="#2d2d2d" Foreground="White"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Clad index (n_clad):"
                               Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="2" Grid.Column="2"
                                  Value="{Binding CladIndex}"
                                  Minimum="1.0" Maximum="4.0" Increment="0.01"
                                  FormatString="F3"
                                  Background="#2d2d2d" Foreground="White"/>
                </Grid>

                <Separator Background="#3d3d3d"/>

                <!-- Solver settings -->
                <TextBlock Text="Solver settings" Foreground="#aaaaaa" FontSize="11"
                           FontWeight="SemiBold"/>

                <Grid ColumnDefinitions="*,8,*" RowDefinitions="Auto,8,Auto,8,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Wavelength (nm):"
                               Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="0" Grid.Column="2"
                                  Value="{Binding WavelengthNm}"
                                  Minimum="400" Maximum="2500" Increment="10"
                                  FormatString="F0"
                                  Background="#2d2d2d" Foreground="White"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Max modes:"
                               Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="2" Grid.Column="2"
                                  Value="{Binding NumModes}"
                                  Minimum="1" Maximum="20" Increment="1"
                                  FormatString="F0"
                                  Background="#2d2d2d" Foreground="White"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Backend:"
                               Foreground="Gray" FontSize="11" VerticalAlignment="Center"/>
                    <ComboBox Grid.Row="4" Grid.Column="2"
                              ItemsSource="{x:Static vm:ModeSolverViewModel.AvailableBackends}"
                              SelectedItem="{Binding SelectedBackend}"
                              Background="#2d2d2d" Foreground="White"/>
                </Grid>

                <Separator Background="#3d3d3d"/>

                <!-- Status -->
                <TextBlock Text="{Binding StatusText}" Foreground="#dddddd" FontSize="11"
                           TextWrapping="Wrap"/>

                <!-- Results table -->
                <StackPanel IsVisible="{Binding HasResult}" Spacing="6">
                    <TextBlock Text="Results" Foreground="#aaaaaa" FontSize="11"
                               FontWeight="SemiBold"/>

                    <!-- Header row -->
                    <Border Background="#3a3a3a" Padding="4,3">
                        <Grid ColumnDefinitions="70,48,85,75,55">
                            <TextBlock Grid.Column="0" Text="λ (µm)"  Foreground="#bbbbbb" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="Mode"    Foreground="#bbbbbb" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="n_eff"   Foreground="#bbbbbb" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="n_g"     Foreground="#bbbbbb" FontSize="11" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="Pol."    Foreground="#bbbbbb" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>

                    <!-- Data rows -->
                    <ItemsControl ItemsSource="{Binding Modes}" MaxHeight="160">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,2" Background="Transparent">
                                    <Grid ColumnDefinitions="70,48,85,75,55">
                                        <TextBlock Grid.Column="0" Text="{Binding Wavelength, StringFormat=F4}" Foreground="White" FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ModeIndex}"                   Foreground="White" FontSize="11"/>
                                        <TextBlock Grid.Column="2" Text="{Binding NEff, StringFormat=F5}"       Foreground="#aaffaa" FontSize="11"/>
                                        <TextBlock Grid.Column="3" Text="{Binding NGroup, StringFormat=F4}"     Foreground="#aaaaff" FontSize="11"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Polarisation}"                Foreground="#ffddaa" FontSize="11"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Raw stderr expander — shown only on failure with stderr -->
                <Expander IsVisible="{Binding HasStderr}"
                          Header="Raw solver output (stderr)"
                          Foreground="#cc8888">
                    <TextBox Text="{Binding RawStderr}"
                             IsReadOnly="True"
                             Background="#2a1a1a"
                             Foreground="#ff9999"
                             FontFamily="Monospace"
                             FontSize="10"
                             MaxHeight="120"
                             TextWrapping="Wrap"/>
                </Expander>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
