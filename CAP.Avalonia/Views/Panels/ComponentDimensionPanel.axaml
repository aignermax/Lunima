<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CAP.Avalonia.ViewModels.Diagnostics"
             x:Class="CAP.Avalonia.Views.Panels.ComponentDimensionPanel"
             x:DataType="vm:ComponentDimensionViewModel">
    <StackPanel>
        <Separator Margin="0,20,0,10" Background="#3d3d3d"/>
        <TextBlock Text="Component Dimensions:" Foreground="LightBlue" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <Button Content="Validate Dimensions" Command="{Binding RunValidationCommand}"
                MinWidth="110" Margin="0,5,0,5" Padding="8,4" Background="#3d4d5d" HorizontalAlignment="Stretch"/>
        <TextBlock Text="{Binding StatusText}" Foreground="Gray" FontSize="10" Margin="0,0,0,3"
                   IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        <StackPanel Margin="0,5,0,0" IsVisible="{Binding HasIssues}">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                <TextBlock Text="⚠️ Dimension Issues:" Foreground="Orange" FontSize="10" FontWeight="SemiBold"/>
                <Button Content="📋" Command="{Binding CopyIssuesToClipboardCommand}"
                        Width="24" Height="20" Margin="5,0,0,0" Padding="0" Background="#3d3d5d"
                        ToolTip.Tip="Copy issues to clipboard"/>
            </StackPanel>
            <ScrollViewer MaxHeight="120">
                <ItemsControl ItemsSource="{Binding Issues}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2,0,4">
                                <TextBlock Text="{Binding ComponentName}" Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Issue}" Foreground="Orange" FontSize="9" Margin="2,0,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="2,0,0,0">
                                    <TextBlock Text="Current: " Foreground="Gray" FontSize="9"/>
                                    <TextBlock Text="{Binding CurrentDimensions}" Foreground="LightGray" FontSize="9"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="2,0,0,0">
                                    <TextBlock Text="Recommended: " Foreground="Gray" FontSize="9"/>
                                    <TextBlock Text="{Binding RecommendedDimensions}" Foreground="LightGreen" FontSize="9"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </StackPanel>
</UserControl>
