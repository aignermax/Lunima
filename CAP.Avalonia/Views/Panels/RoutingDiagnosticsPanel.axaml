<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CAP.Avalonia.ViewModels.Diagnostics"
             x:Class="CAP.Avalonia.Views.Panels.RoutingDiagnosticsPanel"
             x:DataType="vm:RoutingDiagnosticsViewModel">
    <StackPanel>
        <Separator Margin="0,20,0,10" Background="#3d3d3d"/>
        <TextBlock Text="Routing Diagnostics:" Foreground="Salmon" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <Button Content="Analyze Routes" Command="{Binding RunDiagnosticsCommand}"
                MinWidth="110" Margin="0,5,0,5" Padding="8,4" Background="#5d3d3d" HorizontalAlignment="Stretch"
                IsEnabled="{Binding IsAnalyzing, Converter={x:Static BoolConverters.Not}}"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
            <Button Content="Export JSON" Command="{Binding ExportPathsJsonCommand}"
                    MinWidth="100" Margin="0,0,5,0" Padding="8,4" Background="#3d3d5d"/>
            <Button Content="📋" Command="{Binding CopyPathsJsonToClipboardCommand}"
                    Width="36" Background="#3d3d5d" ToolTip.Tip="Copy JSON to clipboard"/>
        </StackPanel>
        <TextBlock Text="{Binding StatusText}" Foreground="Gray" FontSize="10" Margin="0,0,0,3"
                   IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,5"
                    IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="Valid: " Foreground="Gray"/>
            <TextBlock Text="{Binding ValidConnections}" Foreground="LightGreen"/>
            <TextBlock Text="/" Foreground="Gray"/>
            <TextBlock Text="{Binding TotalConnections}" Foreground="White"/>
            <TextBlock Text="  Issues: " Foreground="Gray"/>
            <TextBlock Text="{Binding IssueCount}" Foreground="Salmon"/>
        </StackPanel>
        <ScrollViewer MaxHeight="150" Margin="0,5,0,0"
                      IsVisible="{Binding ResultText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding ResultText}" Foreground="LightGray"
                       FontFamily="Consolas" FontSize="9" TextWrapping="NoWrap"/>
        </ScrollViewer>
    </StackPanel>
</UserControl>
