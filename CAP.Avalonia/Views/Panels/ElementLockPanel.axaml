<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CAP.Avalonia.ViewModels.Library"
             x:Class="CAP.Avalonia.Views.Panels.ElementLockPanel"
             x:DataType="vm:ElementLockViewModel">
    <StackPanel>
        <Separator Margin="0,20,0,10" Background="#3d3d3d"/>
        <TextBlock Text="Lock Elements:" Foreground="Gold" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <TextBlock Foreground="Gray" FontSize="10" Margin="0,0,0,10" TextWrapping="Wrap">
            Lock components to prevent moving, rotating, or deleting.
        </TextBlock>
        <StackPanel IsVisible="{Binding HasSelection}">
            <TextBlock Text="Selected Components:" Foreground="Gray" Margin="0,0,0,5"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Lock"
                        Command="{Binding LockSelectedComponentsCommand}"
                        Width="80" Margin="0,0,5,0" Background="#5d3d3d"/>
                <Button Content="Unlock"
                        Command="{Binding UnlockSelectedComponentsCommand}"
                        Width="80" Margin="5,0,0,0" Background="#3d5d3d"/>
            </StackPanel>
        </StackPanel>
        <Button Content="Unlock All Components"
                Command="{Binding UnlockAllComponentsCommand}"
                Width="160" Margin="0,5,0,5"
                Background="#3d4d5d"/>
        <Button Content="Unlock All Connections"
                Command="{Binding UnlockAllConnectionsCommand}"
                Width="160" Margin="0,0,0,5"
                Background="#3d4d5d"/>
        <StackPanel Orientation="Horizontal" Margin="0,10,0,5">
            <TextBlock Text="Locked: " Foreground="Gray"/>
            <TextBlock Text="{Binding LockedComponentCount}" Foreground="Orange"/>
            <TextBlock Text=" components, " Foreground="Gray"/>
            <TextBlock Text="{Binding LockedConnectionCount}" Foreground="Orange"/>
            <TextBlock Text=" connections" Foreground="Gray"/>
        </StackPanel>
        <TextBlock Text="{Binding StatusText}"
                   Foreground="LightGreen" FontSize="10" Margin="0,0,0,5"
                   IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    </StackPanel>
</UserControl>
