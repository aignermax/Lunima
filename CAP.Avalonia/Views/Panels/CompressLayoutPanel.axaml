<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CAP.Avalonia.ViewModels.Analysis"
             x:Class="CAP.Avalonia.Views.Panels.CompressLayoutPanel"
             x:DataType="vm:CompressLayoutViewModel">
    <StackPanel>
        <Separator Margin="0,20,0,10" Background="#3d3d3d"/>
        <TextBlock Text="Layout Compression:" Foreground="Cyan" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <TextBlock Text="Minimize chip area while maintaining connectivity."
                   Foreground="Gray" FontSize="10" Margin="0,0,0,8" TextWrapping="Wrap"/>
        <Button Content="Compress Layout"
                Command="{Binding CompressLayoutCommand}"
                Width="160" Margin="0,5,0,5"
                Background="#3d5d5d"
                IsEnabled="{Binding IsCompressing, Converter={x:Static BoolConverters.Not}}"/>
        <ProgressBar Value="{Binding CurrentIteration}"
                     Maximum="{Binding MaxIterations}"
                     Height="4" Margin="0,5,0,5"
                     IsVisible="{Binding IsCompressing}"
                     Foreground="Cyan"/>
        <TextBlock Text="{Binding StatusText}"
                   Foreground="Gray" FontSize="10" Margin="0,0,0,5"
                   IsVisible="{Binding StatusText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        <TextBlock Text="{Binding ResultText}"
                   Foreground="LightCyan" FontSize="10" Margin="0,5,0,5"
                   TextWrapping="Wrap"
                   IsVisible="{Binding ResultText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    </StackPanel>
</UserControl>
