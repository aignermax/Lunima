<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CAP.Avalonia.ViewModels"
             x:Class="CAP.Avalonia.Views.Panels.OnaAnalysisPanel"
             x:DataType="vm:MainViewModel">

    <StackPanel>
        <Separator Margin="0,20,0,10" Background="#3d3d3d"/>
        <TextBlock Text="ONA Analyzer Tool:" Foreground="Cyan" Margin="0,0,0,5" FontWeight="SemiBold"/>
        <TextBlock Foreground="Gray" FontSize="10" Margin="0,0,0,8" TextWrapping="Wrap">
            Place an "ONA Analyzer" component from the Analysis library, connect its source pin to the input of your device, and its measurement pins to the outputs. Then select the analyzer and click below.
        </TextBlock>

        <Button Content="Open ONA Sweep..."
                Command="{Binding RightPanel.OnaAnalysis.OpenWindowCommand}"
                Width="180" HorizontalAlignment="Left"
                Background="#3d5d5d"
                IsEnabled="{Binding Canvas.SelectedComponent.Component.IsAnalysisTool, FallbackValue=False}"/>

        <TextBlock Foreground="Gray" FontSize="9" Margin="0,4,0,0"
                   Text="(Button enabled when an ONA Analyzer is selected on the canvas.)"/>
    </StackPanel>

</UserControl>
