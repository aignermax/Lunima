<?xml version="1.0" encoding="utf-8"?>
<!--
  Lunima MSI installer definition (WiX v4).

  This file defines:
    - Package metadata (name, version, upgrade code)
    - .NET 8 Desktop Runtime prerequisite check
    - Installation directory: %ProgramFiles%\Lunima
    - Desktop shortcut with Lunima icon
    - Start Menu shortcut with Lunima icon
    - MajorUpgrade rule (prevents downgrades, handles upgrades cleanly)

  IMPORTANT: Never change UpgradeCode after first release — it is the
  permanent identity used to locate installed versions for upgrades.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:netfx="http://wixtoolset.org/schemas/v4/wxs/netfx">

  <Package
      Name="Lunima"
      Manufacturer="Lunima Team"
      Version="0.5.1"
      UpgradeCode="F8E4A2B6-3C5D-7F91-A0E4-B8D6F2C4A8E0"
      Scope="perMachine"
      Compressed="yes">

    <!-- ─────────────────────────────────────────────────────── -->
    <!-- Upgrade behaviour                                        -->
    <!-- ─────────────────────────────────────────────────────── -->

    <!--
      Remove any existing Lunima installation before installing
      the new version (MajorUpgrade), and block downgrading.
    -->
    <MajorUpgrade
        DowngradeErrorMessage="A newer version of Lunima is already installed. Uninstall it before proceeding." />

    <MediaTemplate EmbedCab="yes" />

    <!-- ─────────────────────────────────────────────────────── -->
    <!-- Branding                                                 -->
    <!-- ─────────────────────────────────────────────────────── -->

    <!-- Icon shown in Programs and Features / Add-Remove Programs -->
    <Icon Id="LunimaIcon.ico" SourceFile="LunimaIcon.ico" />
    <Property Id="ARPPRODUCTICON" Value="LunimaIcon.ico" />
    <Property Id="ARPHELPLINK"    Value="https://github.com/aignermax/Connect-A-PIC-Pro" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/aignermax/Connect-A-PIC-Pro" />

    <!-- ─────────────────────────────────────────────────────── -->
    <!-- .NET 8 Desktop Runtime prerequisite                     -->
    <!-- ─────────────────────────────────────────────────────── -->

    <!--
      Detect whether .NET 8 Desktop Runtime (x64) is present.
      The DOTNET8_PRESENT property is set to "1" when found.
    -->
    <netfx:DotNetCompatibilityCheck
        Property="DOTNET8_PRESENT"
        Platform="x64"
        RollForward="latestMajor"
        RuntimeType="desktop"
        Version="8.0.0" />

    <!--
      Block installation if .NET 8 is absent (except during uninstall
      or upgrade where the package is already registered).
    -->
    <Condition
        Message="Lunima requires the .NET 8 Desktop Runtime (x64) or later.&#13;&#10;&#13;&#10;Please download and install it from:&#13;&#10;https://dotnet.microsoft.com/download/dotnet/8.0">
      <![CDATA[Installed OR DOTNET8_PRESENT]]>
    </Condition>

    <!-- ─────────────────────────────────────────────────────── -->
    <!-- Installer UI                                             -->
    <!-- ─────────────────────────────────────────────────────── -->

    <!--
      WixUI_InstallDir: prompts for the install directory, then
      installs without per-feature selection dialogs.
    -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLDIR" />

    <!-- ─────────────────────────────────────────────────────── -->
    <!-- Directory structure                                      -->
    <!-- ─────────────────────────────────────────────────────── -->

    <!-- %ProgramFiles%\Lunima  (64-bit) -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="Lunima" />
    </StandardDirectory>

    <!-- Desktop -->
    <StandardDirectory Id="DesktopFolder" />

    <!-- Start Menu  →  Programs\Lunima -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="LunimaStartMenuDir" Name="Lunima" />
    </StandardDirectory>

    <!-- ─────────────────────────────────────────────────────── -->
    <!-- Desktop shortcut component                              -->
    <!-- ─────────────────────────────────────────────────────── -->

    <!--
      Non-advertised shortcut on the Desktop.
      KeyPath is a registry value so Windows Installer can track
      the component reliably.
    -->
    <Component Id="DesktopShortcutComp" Directory="DesktopFolder" Guid="A1F3C5E7-B2D4-6F80-91A3-C5E7B9D1F3A5">
      <Shortcut
          Id="DesktopShortcut"
          Name="Lunima"
          Description="Lunima – Photonic Circuit Designer"
          Target="[INSTALLDIR]CAP.Desktop.exe"
          WorkingDirectory="INSTALLDIR"
          Icon="LunimaIcon.ico"
          IconIndex="0" />
      <RegistryValue
          Root="HKCU"
          Key="Software\Lunima"
          Name="DesktopShortcut"
          Type="integer"
          Value="1"
          KeyPath="yes" />
    </Component>

    <!-- ─────────────────────────────────────────────────────── -->
    <!-- Start Menu shortcut component                           -->
    <!-- ─────────────────────────────────────────────────────── -->

    <Component Id="StartMenuShortcutComp" Directory="LunimaStartMenuDir" Guid="B2D4E6F8-C3A5-7091-A2B4-D6E8F0A2C4B6">
      <Shortcut
          Id="StartMenuShortcut"
          Name="Lunima"
          Description="Lunima – Photonic Circuit Designer"
          Target="[INSTALLDIR]CAP.Desktop.exe"
          WorkingDirectory="INSTALLDIR"
          Icon="LunimaIcon.ico"
          IconIndex="0" />
      <!-- Remove the Programs\Lunima folder on uninstall -->
      <RemoveFolder Id="RemoveLunimaStartMenuDir" Directory="LunimaStartMenuDir" On="uninstall" />
      <RegistryValue
          Root="HKCU"
          Key="Software\Lunima"
          Name="StartMenuShortcut"
          Type="integer"
          Value="1"
          KeyPath="yes" />
    </Component>

    <!-- ─────────────────────────────────────────────────────── -->
    <!-- Feature tree                                            -->
    <!-- ─────────────────────────────────────────────────────── -->

    <!--
      Single feature that includes:
        - All application files (harvested from publish directory)
        - Desktop shortcut
        - Start Menu shortcut
    -->
    <Feature Id="MainFeature" Title="Lunima" Level="1">
      <!-- Auto-harvested application files (from HarvestDirectory in .wixproj) -->
      <ComponentGroupRef Id="HarvestedAppFiles" />
      <!-- Shortcuts -->
      <ComponentRef Id="DesktopShortcutComp" />
      <ComponentRef Id="StartMenuShortcutComp" />
    </Feature>

  </Package>
</Wix>
